# MFH Global Football — environment variables
# Copy this file to .env and fill in the values. All are optional.
# The site builds and renders correctly with none of them set (graceful fallbacks).
# Only variables prefixed with PUBLIC_ are exposed to the static build.

# Consultation booking embed (Calendly or similar). When set, the contact page
# shows the embed instead of the email fallback.
PUBLIC_BOOKING_URL=

# Form endpoint for the "Share your footage" form (Formspree or Web3Forms style).
# When set, the form POSTs here. When empty, the form falls back to email.
PUBLIC_FORM_ENDPOINT=

# Address used for the booking email fallback and the contact details block.
# Client confirmed: info@mfhglobal.football is the site email.
PUBLIC_CONTACT_EMAIL=info@mfhglobal.football
