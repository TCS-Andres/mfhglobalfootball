---
import BaseLayout from '../layouts/BaseLayout.astro';
import Home from '../components/Home.astro';

const lang = 'en';
const title = 'MFH Global Football | FIFA-Licensed Football Agency';
const description =
  'MFH Global Football is a FIFA-licensed, faith-driven agency that guides players and families through every decision on the path to professional football. South Florida and Colombia.';
---

<BaseLayout lang={lang} title={title} description={description}>
  <Home lang={lang} />
</BaseLayout>
