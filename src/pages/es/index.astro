---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Home from '../../components/Home.astro';

const lang = 'es';
const title = 'MFH Global Football | Agencia de Fútbol con Licencia FIFA';
const description =
  'MFH Global Football es una agencia con licencia FIFA y guiada por la fe que acompaña a jugadores y familias en cada decisión del camino al fútbol profesional. Sur de la Florida, Colombia y Europa.';
---

<BaseLayout lang={lang} title={title} description={description}>
  <Home lang={lang} />
</BaseLayout>
