---
import { t, type Lang } from '../../i18n/ui';
import CtaBanner from '../CtaBanner.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const blocks = ['ab.traj', 'ab.lic', 'ab.bil', 'ab.fam'];
---

<section class="page-hero">
  <img class="page-hero__bg" src="/photos/bridge-colombia.jpg" alt="" />
  <div class="page-hero__scrim"></div>
  <div class="wrap">
    <span class="eyebrow"><i class="pent"></i><span>{t(lang, 'ab.eyebrow')}</span></span>
    <h1>{t(lang, 'ab.h1')}</h1>
    <p>{t(lang, 'ab.intro')}</p>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <div class="media-slot reveal-scale" style="aspect-ratio:21/9;margin-bottom:48px">
      <img src="/photos/about-banner.jpg" alt={t(lang, 'media.altStadium')} width="1600" height="686" loading="lazy" />
    </div>
    <div class="prose-grid">
      {blocks.map((k, i) => (
        <div class="prose-block reveal" style={`--d:${i * 90}ms`}>
          <h2>{t(lang, `${k}.h2`)}</h2>
          <p>{t(lang, `${k}.body`)}</p>
        </div>
      ))}
      <div class="prose-block reveal">
        <h2>{t(lang, 'ab.faith.h2')}</h2>
        <p>{t(lang, 'ab.faith.body')}</p>
        <p class="about-verse">{t(lang, 'ab.verse')}</p>
      </div>
    </div>
  </div>
</section>

<CtaBanner lang={lang} />
