---
import { t, type Lang } from '../../i18n/ui';
import CtaBanner from '../CtaBanner.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const stories = ['pl.story1', 'pl.story2', 'pl.story3'];
---

<section class="page-hero">
  <img class="page-hero__bg" src="/photos/quote-parallax.jpg" alt="" />
  <div class="page-hero__scrim"></div>
  <div class="wrap">
    <span class="eyebrow"><i class="pent"></i><span>{t(lang, 'pl.eyebrow')}</span></span>
    <h1>{t(lang, 'pl.h1')}</h1>
    <p>{t(lang, 'pl.intro')}</p>
  </div>
</section>

<!-- Four step plan, expanded -->
<section class="section">
  <div class="wrap">
    <div class="plan-grid">
      {[1, 2, 3, 4].map((n, i) => (
        <div class="step reveal" style={`--d:${i * 110}ms`}><div class="num">{n}</div><h3>{t(lang, `pl.s${n}.t`)}</h3><p>{t(lang, `pl.s${n}.d`)}</p></div>
      ))}
    </div>
  </div>
</section>

<!-- Image break -->
<section class="section" style="padding-top:0">
  <div class="wrap">
    <div class="media-slot reveal-scale" style="aspect-ratio:21/8">
      <img src="/photos/about-banner.jpg" alt={t(lang, 'media.altStadium')} width="1600" height="610" loading="lazy" />
    </div>
  </div>
</section>

<!-- Teaching stories -->
<section class="section sky">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow"><i class="pent"></i><span>{t(lang, 'pl.stories.eyebrow')}</span></span>
      <h2>{t(lang, 'pl.stories.h2')}</h2>
      <p class="lead">{t(lang, 'pl.stories.intro')}</p>
    </div>
    <div class="stories">
      {stories.map((k, i) => (
        <div class="story reveal-scale" style={`--d:${i * 110}ms`}><i class="pent"></i><h3>{t(lang, `${k}.t`)}</h3><p>{t(lang, `${k}.d`)}</p></div>
      ))}
    </div>
  </div>
</section>

<CtaBanner lang={lang} />
