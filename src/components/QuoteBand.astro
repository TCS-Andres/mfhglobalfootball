---
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  img?: string;
  altKey?: string;
  smallKey?: string;
  bigKey?: string;
}
const {
  lang,
  img = '/photos/quote-parallax.jpg',
  altKey = 'media.altQuote',
  smallKey = 'quote.small',
  bigKey = 'quote.big',
} = Astro.props;
---

<section class="quote-band" data-quote-band>
  <div class="wrap">
    <div class="quote-band__frame">
      <div class="quote-band__media">
        <img src={img} alt={t(lang, altKey)} width="1600" height="1067" loading="lazy" />
      </div>
      <div class="quote-band__content">
        <p class="quote-band__small">{t(lang, smallKey)}</p>
        <p class="quote-band__big">{t(lang, bigKey)}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .quote-band {
    padding: 24px 0;
  }
  .quote-band__frame {
    position: relative;
    height: clamp(460px, 80vh, 760px);
    overflow: hidden;
    border-radius: 24px;
    background: var(--blue-deep);
  }
  .quote-band__media {
    position: absolute;
    inset: -10% 0;
    height: 120%;
    will-change: transform;
  }
  .quote-band__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .quote-band__content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(28px, 5vw, 80px);
    color: #fff;
    mix-blend-mode: difference;
  }
  .quote-band__small {
    width: min(52vw, 640px);
    align-self: flex-end;
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(0.95rem, 1.9vw, 1.6rem);
    line-height: 1.35;
    letter-spacing: 0.01em;
  }
  .quote-band__big {
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    font-size: clamp(2rem, 6.5vw, 5.5rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    max-width: 16ch;
  }
  @media (max-width: 680px) {
    .quote-band__small {
      width: 100%;
      align-self: flex-start;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .quote-band__media {
      transform: none !important;
    }
  }
</style>

<script>
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    document.querySelectorAll('[data-quote-band]').forEach((band) => {
      const media = band.querySelector('.quote-band__media') as HTMLElement | null;
      if (!media) return;
      let ticking = false;
      const update = () => {
        const rect = band.getBoundingClientRect();
        const p = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
        const clamped = Math.max(0, Math.min(1, p));
        media.style.transform = `translateY(${((clamped - 0.5) * 12).toFixed(2)}%)`;
        ticking = false;
      };
      const onScroll = () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      };
      addEventListener('scroll', onScroll, { passive: true });
      addEventListener('resize', onScroll, { passive: true });
      update();
    });
  }
</script>
