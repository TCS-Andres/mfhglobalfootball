---
import { t, localizePath, type Lang } from '../i18n/ui';
import QuoteBand from './QuoteBand.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const contact = localizePath('/contact', lang);
const plan = localizePath('/the-mfh-plan', lang);
const about = localizePath('/about', lang);
const services = localizePath('/services', lang);

const strip = ['strip.1', 'strip.2', 'strip.3', 'strip.4', 'strip.5', 'strip.6'];
const problems = ['p1', 'p2', 'p3', 'p4'];
const who = ['w1', 'w2', 'w3'];
const stats = [
  { n: 'stat1.n', l: 'stat1.l', count: true },
  { n: 'stat2.n', l: 'stat2.l', count: true },
  { n: 'stat3.n', l: 'stat3.l', count: true },
  { n: 'stat4.n', l: 'stat4.l', count: false },
];
---

<!-- HERO (Modern Sport) -->
<section class="hero" data-hero>
  <img class="hero__bg" src="/photos/hero-action.jpg" alt="" fetchpriority="high" />
  <div class="hero__scrim" aria-hidden="true"></div>
  <div class="hero__inner">
    <span class="eyebrow hero-in" style="--i:0"><i class="pent"></i><span>{t(lang, 'hero.eyebrow')}</span></span>
    <h1 class="hero__title hero-in" style="--i:1" set:html={t(lang, 'hero.h1')} />
    <p class="hero__sub hero-in" style="--i:2">{t(lang, 'hero.sub')}</p>
    <div class="actions hero-in" style="--i:3">
      <a href={contact} class="btn btn-primary">{t(lang, 'hero.cta1')}</a>
      <a href={plan} class="btn btn-ghost">{t(lang, 'hero.cta2')}</a>
    </div>
    <div class="hero__creds hero-in" style="--i:4">
      <span>{t(lang, 'strip.1')}</span>
      <span>{t(lang, 'strip.2')}</span>
      <span>{t(lang, 'strip.3')}</span>
      <span>{t(lang, 'strip.4')}</span>
    </div>
  </div>
</section>

<!-- THE LANDSCAPE -->
<section class="section" id="landscape">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow"><i class="pent"></i><span>{t(lang, 'problem.eyebrow')}</span></span>
      <h2>{t(lang, 'problem.h2')}</h2>
      <p class="lead">{t(lang, 'problem.intro')}</p>
    </div>
    <div class="grid g4">
      {problems.map((k, i) => (
        <div class="card reveal" style={`--d:${i * 90}ms`}><i class="pent"></i><h3>{t(lang, `${k}.t`)}</h3><p>{t(lang, `${k}.d`)}</p></div>
      ))}
    </div>
  </div>
</section>

<!-- MEET BERT -->
<section class="section sky" id="guide">
  <div class="wrap">
    <div class="guide has-media">
      <div class="media-slot media-tall reveal-l">
        <img src="/photos/guide-coach.jpg" alt={t(lang, 'media.altCoach')} width="900" height="1200" loading="lazy" />
      </div>
      <div class="body reveal-r">
        <span class="eyebrow"><i class="pent"></i><span>{t(lang, 'guide.eyebrow')}</span></span>
        <h2>{t(lang, 'guide.h2')}</h2>
        <p>{t(lang, 'guide.body')}</p>
        <div class="panel">
          <h3>{t(lang, 'guide.panel')}</h3>
          <ul>
            <li><i class="pent"></i><span>{t(lang, 'guide.l1')}</span></li>
            <li><i class="pent"></i><span>{t(lang, 'guide.l2')}</span></li>
            <li><i class="pent"></i><span>{t(lang, 'guide.l3')}</span></li>
            <li><i class="pent"></i><span>{t(lang, 'guide.l4')}</span></li>
          </ul>
        </div>
        <a href={about} class="btn btn-outline">{t(lang, 'guide.cta')}</a>
      </div>
    </div>
  </div>
</section>

<!-- STATS BAND -->
<section class="section stats">
  <div class="wrap">
    <span class="eyebrow"><i class="pent"></i><span>{t(lang, 'stats.eyebrow')}</span></span>
    <div class="stat-grid">
      {stats.map((s, i) => (
        <div class="stat reveal-scale" style={`--d:${i * 110}ms`}>
          <div class="n" class:list={[{ count: s.count }]} data-count={s.count ? t(lang, s.n) : undefined}>{t(lang, s.n)}</div>
          <div class="l">{t(lang, s.l)}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section" id="plan">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow"><i class="pent"></i><span>{t(lang, 'plan.eyebrow')}</span></span>
      <h2>{t(lang, 'plan.h2')}</h2>
    </div>
    <div class="plan-grid">
      {[1, 2, 3, 4].map((n, i) => (
        <div class="step reveal" style={`--d:${i * 110}ms`}><div class="num">{n}</div><h3>{t(lang, `s${n}.t`)}</h3><p>{t(lang, `s${n}.d`)}</p></div>
      ))}
    </div>
  </div>
</section>

<!-- PROMISE (bold band) -->
<QuoteBand
  lang={lang}
  img="/photos/promise-bg.jpg"
  altKey="media.altPromise"
  smallKey="quote.promiseSmall"
  bigKey="quote.promiseBig"
/>

<!-- BRIDGE -->
<section class="section sky" id="bridge">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow"><i class="pent"></i><span>{t(lang, 'bridge.eyebrow')}</span></span>
      <h2>{t(lang, 'bridge.h2')}</h2>
      <p class="lead">{t(lang, 'bridge.body')}</p>
    </div>
    <div class="bridge-row">
      <div class="bridge-card reveal-l">
        <div class="media-slot" style="aspect-ratio:16/10;margin-bottom:18px"><img src="/photos/bridge-southflorida.jpg" alt={t(lang, 'media.altSF')} width="1000" height="625" loading="lazy" /></div>
        <h3>{t(lang, 'bridge.left')}</h3><p>{t(lang, 'bridge.leftd')}</p>
      </div>
      <div class="bridge-mid"><span class="bridge-line"></span><i class="pent"></i><span class="bridge-line"></span></div>
      <div class="bridge-card reveal-r">
        <div class="media-slot" style="aspect-ratio:16/10;margin-bottom:18px"><img src="/photos/bridge-colombia.jpg" alt={t(lang, 'media.altColombia')} width="1000" height="625" loading="lazy" /></div>
        <h3>{t(lang, 'bridge.right')}</h3><p>{t(lang, 'bridge.rightd')}</p>
      </div>
    </div>
  </div>
</section>

<!-- WHO WE WORK WITH -->
<section class="section" id="who">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow"><i class="pent"></i><span>{t(lang, 'who.eyebrow')}</span></span>
      <h2>{t(lang, 'who.h2')}</h2>
    </div>
    <div class="grid g3">
      {who.map((k, i) => (
        <div class="card reveal" style={`--d:${i * 90}ms`}><i class="pent"></i><h3>{t(lang, `${k}.t`)}</h3><p>{t(lang, `${k}.d`)}</p></div>
      ))}
    </div>
  </div>
</section>

<!-- PARALLAX QUOTE BAND -->
<QuoteBand lang={lang} />

<!-- SERVICES PREVIEW -->
<section class="section sky" id="services">
  <div class="wrap">
    <div class="head">
      <span class="eyebrow"><i class="pent"></i><span>{t(lang, 'services.eyebrow')}</span></span>
      <h2>{t(lang, 'services.h2')}</h2>
      <p class="lead">{t(lang, 'services.intro')}</p>
    </div>
    <div class="svc">
      <div class="card reveal" style="--d:0ms"><i class="pent"></i><h3>{t(lang, 'b1.t')}</h3><p class="items">{t(lang, 'b1.i')}</p></div>
      <div class="card reveal" style="--d:90ms"><i class="pent"></i><h3>{t(lang, 'b2.t')}</h3><p class="items">{t(lang, 'b2.i')}</p></div>
      <div class="card reveal" style="--d:180ms"><i class="pent"></i><h3>{t(lang, 'b3.t')}</h3><p class="items">{t(lang, 'b3.i')}</p></div>
    </div>
    <div style="margin-top:30px" class="reveal"><a href={services} class="btn btn-outline">{t(lang, 'services.cta')}</a></div>
  </div>
</section>

<!-- CTA BANNER -->
<section class="cta-banner" id="contact">
  <div class="wrap">
    <div>
      <h2>{t(lang, 'cta.h2')}</h2>
      <p>{t(lang, 'cta.sub')}</p>
    </div>
    <a href={contact} class="btn btn-primary">{t(lang, 'cta.consult')}</a>
  </div>
</section>
